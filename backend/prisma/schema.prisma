generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  TECH
}

enum SubStatus {
  PENDING
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum InstallStatus {
  AWAITING_PAYMENT
  SCHEDULED
  INSTALLED
  CANCELLED
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  phone         String?
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
  payments      Payment[]
  tickets       Ticket[]
  equipments    Equipment[]
  dealerProfile Dealer?
}

model Offer {
  id            String         @id @default(uuid())
  name          String
  speed         Int            // Mbps
  quota         Int?           // GB, null for unlimited
  price         Float
  description   String
  isPopular     Boolean        @default(false)
  subscriptions Subscription[]
}

model Subscription {
  id            String         @id @default(uuid())
  user          User           @relation(fields: [userId], references: [id])
  userId        String
  offer         Offer          @relation(fields: [offerId], references: [id])
  offerId       String
  status        SubStatus      @default(PENDING)
  installStatus InstallStatus  @default(AWAITING_PAYMENT)
  scheduledDate DateTime?
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime       @default(now())
}

model Payment {
  id          String        @id @default(uuid())
  user        User          @relation(fields: [userId], references: [id])
  userId      String
  amount      Float
  currency    String        @default("USD")
  method      String        // MoMo, Card, etc.
  status      PaymentStatus @default(PENDING)
  reference   String        @unique // Transaction ID
  createdAt   DateTime      @default(now())
}

model Ticket {
  id        String       @id @default(uuid())
  user      User         @relation(fields: [userId], references: [id])
  userId    String
  category  String
  subject   String
  message   String
  status    TicketStatus @default(OPEN)
  responses Json?        // Array of response objects
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Equipment {
  id           String  @id @default(uuid())
  serialNumber String  @unique
  type         String  // Antenna, Router
  status       String  // STOCK, INSTALLED, FAULTY
  user         User?   @relation(fields: [userId], references: [id])
  userId       String?
}

model CoverageZone {
  id        String @id @default(uuid())
  name      String
  quartier  String
  latitude  Float
  longitude Float
  level     String // GOOD, PARTIAL, NONE
}

model Article {
  id        String   @id @default(uuid())
  title     String
  excerpt   String
  content   String
  image     String?
  author    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Newsletter {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Dealer {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @unique
  companyName String
  address     String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
}
