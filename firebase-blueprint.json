{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information and contact details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subscriptionPlan": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "expired", "none"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName"]
    },
    "Subscription": {
      "title": "Active Subscription",
      "description": "Information about a user's active internet plan.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "planName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "expired", "pending"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "planId", "status"]
    },
    "Payment": {
      "title": "Payment Record",
      "description": "Transactions log for subscriptions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "string" },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["completed", "pending", "failed"] },
        "planId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "amount", "status"]
    },
    "Installation": {
      "title": "Installation Request",
      "description": "Field installation request for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "scheduled", "in_progress", "installed", "failed"] },
        "preferredDate": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "technicianId": { "type": "string" },
        "technicianName": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "address", "status"]
    },
    "Technician": {
      "title": "Field Technician",
      "description": "Technician profile for field operations.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "busy", "offline"] },
        "city": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profile documents."
    },
    "/subscriptions/{userId}": {
      "schema": "Subscription",
      "description": "Active subscription records keyed by userId for easy lookup."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Transaction logs."
    },
    "/installations/{installationId}": {
      "schema": "Installation",
      "description": "Installation requests and records."
    },
    "/technicians/{technicianId}": {
      "schema": "Technician",
      "description": "Field technicians database."
    }
  }
}
